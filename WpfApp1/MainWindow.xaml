<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="오늘의 할일"
        Height="600"
        Width="450"
        ResizeMode="NoResize"
        Background="#F6F8FB">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <!-- 날씨 / 날짜 / 나무 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 카드 -->
            <Border Grid.Column="0"
            Background="White"
            CornerRadius="15"
            Padding="15"
            Margin="0,0,5,0">

                <StackPanel>

                    <TextBlock Text="{Binding CurrentDate}"
                       FontSize="15"
                       Foreground="#64748B"/>

                    <TextBlock Text="{Binding WeatherText}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,5,0,0"/>

                    <TextBlock Text="🌱"
                       FontSize="30"
                       Margin="0,10,0,0"/>

                    <TextBlock Text="{Binding Tree.Level,
                                      StringFormat=Lv.{0}}"/>

                    <TextBlock Text="{Binding Tree.Exp,
                                      StringFormat=EXP {0}}"/>

                </StackPanel>

            </Border>

            <!-- 오른쪽 카드 -->
            <Border Grid.Column="1"
            Background="White"
            CornerRadius="15"
            Padding="15"
            Margin="5,0,0,0">

                <StackPanel VerticalAlignment="Center">
                    <Grid Width="120" 
                          Height="120">

                        <Ellipse
                            Stroke="#E5E7EB"
                            StrokeThickness="10"/>

                        <Ellipse
                            Stroke="#3B82F6"
                            StrokeThickness="10"
                            StrokeDashArray="75 25"/>

                        <TextBlock 
                            Text="25:00"
                            FontSize="24"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>    

                    </Grid>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="1분"
                        Width="50"
                        Margin="3"/>

                        <Button Content="5분"
                        Width="50"
                        Margin="3"/>

                        <Button Content="15분"
                        Width="50"
                        Margin="3"/>

                        <Button Content="30분"
                        Width="50"
                        Margin="3"/>
                    </WrapPanel>

                    <Button Content="시작"
                    Margin="0,10,0,0"/>

                    <Button Content="초기화"
                    Margin="0,10,0,0"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- 입력 영역 -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="15"
                Padding="12"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="35"
                         FontSize="14"
                         Padding="10,5"
                         Text="{Binding NewTodo}" />

                <Button Grid.Column="1"
                        Content="+"
                        Width="40"
                        Height="35"
                        Margin="10,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding AddTodoCommand}" />

            </Grid>

        </Border>

        <!-- Todo 목록 -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="15"
                Padding="10">

            <ListBox ItemsSource="{Binding Todos}"
                     SelectedItem="{Binding SelectedTodo}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch">
                

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Grid Margin="5">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsDone}"/>

                            <TextBlock Grid.Column="1"
                                       Margin="10,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding Title}">

                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding IsDone}"
                                                         Value="True">

                                                <Setter Property="TextDecorations"
                                                        Value="Strikethrough"/>

                                                <Setter Property="Opacity"
                                                        Value="0.5"/>

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>
                                </TextBlock.Style>

                            </TextBlock>

                            <Button Grid.Column="2"
                                    Content="✕"
                                    Width="25"
                                    Height="25"
                                    FontSize="12"
                                    Foreground="White"
                                    Background="#EF4444"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.DelTodoCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />

                        </Grid>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

        </Border>

    </Grid>

</Window>